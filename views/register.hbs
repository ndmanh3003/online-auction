<div class="container mx-auto px-4 py-12 max-w-2xl">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body space-y-6">

            <h2 class="card-title text-3xl justify-center mb-4">Register</h2>

            <form data-register-form class="space-y-5">

                <div class="form-control">
                    <input
                      type="text"
                      name="name"
                      class="input input-bordered w-full"
                      placeholder="Full name"
                    />
                </div>

                <div class="form-control">
                    <input
                      type="text"
                      name="address"
                      class="input input-bordered w-full"
                      placeholder="Address"
                    />
                </div>

                <div class="form-control">
                    <div class="join w-full">
                        <div class="w-full">
                            <input
                              type="email"
                              name="email"
                              class="input input-bordered join-item w-full"
                              placeholder="Email"
                            />
                        </div>
                        <button
                          type="button"
                          data-send-otp-btn
                          class="btn btn-primary join-item"
                        >
                            Send OTP
                        </button>
                    </div>
                    <span data-otp-status class="text-sm text-success mt-1 hidden"></span>
                </div>

                <div data-otp-section class="form-control hidden">
                    <input
                      type="text"
                      name="otp"
                      maxlength="6"
                      class="input input-bordered w-full"
                      placeholder="OTP code"
                    />
                </div>

                <div class="form-control">
                    <input
                      type="password"
                      name="password"
                      class="input input-bordered w-full"
                      placeholder="Password (at least 6 characters)"
                    />
                </div>

                <div class="form-control">
                    <input
                      type="password"
                      name="confirmPassword"
                      class="input input-bordered w-full"
                      placeholder="Confirm password"
                    />
                </div>

                <div data-recaptcha class="g-recaptcha" data-sitekey="{{recaptchaSiteKey}}"></div>

                <button
                  type="submit"
                  data-submit-btn
                  class="btn btn-primary w-full text-lg"
                >
                    Register
                </button>
            </form>

            <div data-message class="mt-2 text-center text-sm hidden"></div>
        </div>
    </div>
</div>
