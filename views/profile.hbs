<div class="container mx-auto px-4 py-12 max-w-2xl">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body space-y-6">
       
            <h2 class="card-title text-3xl justify-center mb-4">Profile</h2>

            <form data-profile-form class="space-y-5">

                <div class="form-control">
                    <input
                      type="text"
                      name="name"
                      class="input input-bordered w-full"
                      placeholder="Full name"
                      value="{{user.name}}"
                    />
                </div>

                <div class="form-control">
                    <input
                      type="email"
                      name="email"
                      disabled
                      class="input input-bordered w-full"
                      placeholder="Email"
                      value="{{user.email}}"
                    />
                </div>

                <div class="form-control">
                    <input
                      type="text"
                      name="address"
                      class="input input-bordered w-full"
                      placeholder="Address"
                      value="{{user.address}}"
                    />
                </div>

                <div class="form-control">
                    <input
                      type="date"
                      name="dateOfBirth"
                      class="input input-bordered w-full"
                      value="{{formatDateInput user.date_of_birth}}"
                    />
                </div>

                <button
                  type="submit"
                  data-submit-btn
                  class="btn btn-primary w-full text-lg"
                >
                    Update
                </button>
            </form>
        </div>
    </div>
</div>

