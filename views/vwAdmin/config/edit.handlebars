{{#> admin-management-layout activeMenu='config'}}
  <div class="mb-8">
    <h1 class="text-[36px] font-semibold text-gray-900">Edit Configuration</h1>
  </div>
  <div class="bg-white rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.08)] border border-gray-200/60 p-8">
    <form
      method="post"
      action="/admin/config/{{config.key}}"
      class="space-y-6"
    >
      <input type="hidden" name="_method" value="PUT">
      <div class="relative mb-6">
        <label for="key" class="block text-sm font-medium text-gray-900 mb-2">Key</label>
        <input
          type="text"
          id="key"
          name="key"
          value="{{config.key}}"
          class="w-full px-4 py-4 border border-gray-200/60 rounded-2xl bg-gray-100 text-gray-600 cursor-not-allowed"
          readonly
          disabled
        />
      </div>
      <div class="relative mb-6">
        <label for="description" class="block text-sm font-medium text-gray-900 mb-2">Description</label>
        <input
          type="text"
          id="description"
          name="description"
          value="{{config.description}}"
          class="w-full px-4 py-4 border border-gray-200/60 rounded-2xl bg-gray-100 text-gray-600 cursor-not-allowed"
          readonly
          disabled
        />
      </div>
      <div class="relative mb-6">
        <label for="type" class="block text-sm font-medium text-gray-900 mb-2">Type</label>
        <input
          type="text"
          id="type"
          name="type"
          value="{{config.type}}"
          class="w-full px-4 py-4 border border-gray-200/60 rounded-2xl bg-gray-100 text-gray-600 cursor-not-allowed"
          readonly
          disabled
        />
      </div>
      <div class="relative mb-6">
        <label for="value" class="block text-sm font-medium text-gray-900 mb-2">Value</label>
        {{#if (eq config.type 'boolean')}}
          <select
            id="value"
            name="value"
            class="w-full px-4 py-4 border border-gray-200/60 rounded-2xl focus:ring-2 focus:ring-black/10 focus:outline-none transition-all duration-300 text-gray-900"
            required
          >
            <option value="true" {{#if (eq config.value 'true')}}selected{{/if}}>true</option>
            <option value="false" {{#if (eq config.value 'false')}}selected{{/if}}>false</option>
          </select>
        {{else if (eq config.type 'number')}}
          <input
            type="number"
            id="value"
            name="value"
            value="{{config.value}}"
            class="w-full px-4 py-4 border border-gray-200/60 rounded-2xl focus:ring-2 focus:ring-black/10 focus:outline-none transition-all duration-300 text-gray-900"
            required
          />
        {{else}}
          <input
            type="text"
            id="value"
            name="value"
            value="{{config.value}}"
            class="w-full px-4 py-4 border border-gray-200/60 rounded-2xl focus:ring-2 focus:ring-black/10 focus:outline-none transition-all duration-300 text-gray-900"
            required
          />
        {{/if}}
      </div>
      <div class="flex gap-4">
        <button
          type="submit"
          class="px-6 py-4 bg-blue-600 text-white rounded-xl shadow-[0_4px_20px_rgba(37,99,235,0.3)] hover:bg-blue-700 hover:scale-105 hover:shadow-lg transition-all duration-300 ease-out font-medium"
        >
          Save Changes
        </button>
        <a
          href="/admin/config"
          class="px-6 py-4 bg-gray-200 text-gray-900 rounded-xl hover:bg-gray-300 transition-all duration-300 ease-out font-medium"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
{{/admin-management-layout}}

